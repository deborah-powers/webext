{
	"manifest_version": 2,
	"name": "remplir biblio",
	"version": "1.0",
	"description": "remplir le site de démo de la dila",
	"icons": { "48": "icon-128.svg" },
	"permissions": [ "tabs", "activeTab", "scripting" ],
	"page_action": {
		"default_icon": "icon-128.svg",
		"default_title": "remplir biblio",
		"default_popup": "menu.html",
		"show_matches": [ "<all_urls>" ],
		"pinned": true
	},
	"browser_specific_settings": { "gecko": { "id": "dila-biblio@deborah-powers.fr" }}
}